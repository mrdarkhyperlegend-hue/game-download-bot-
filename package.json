{
  "name": "whatsapp-downloader-bots",
  "version": "2.0.0",
  "description": "WhatsApp Bots for Movie and Game Downloads using Baileys, Web Scraping, and Epic Games API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:movie": "node index.js",
    "start:game": "node game-bot.js",
    "start:both": "concurrently \"npm run start:movie\" \"npm run start:game\"",
    "dev": "nodemon index.js",
    "dev:game": "nodemon game-bot.js"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "movie-downloader",
    "game-downloader",
    "baileys",
    "epic-games",
    "automation",
    "web-scraping"
  ],
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.21",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "pino": "^8.21.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  },
  "author": "Suneth Karunarathna",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrdarkhyperlegend-hue/movie-Dl.git"
  },
  "homepage": "https://github.com/mrdarkhyperlegend-hue/movie-Dl#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
